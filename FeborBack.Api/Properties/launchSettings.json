{
    "$schema": "https://json.schemastore.org/launchsettings.json",
    "profiles": {
        "FeborBack.Api": { // nombre del perfil (aparece en el combo de depuración)
            "commandName": "Project",
            "dotnetRunMessages": true,

            // abre el navegador automáticamente
            "launchBrowser": true,
            // navega directo a la UI de Swagger
            "launchUrl": "swagger",

            // puertos HTTPS y HTTP que usará dotnet run
            "applicationUrl": "https://localhost:7097;http://localhost:5224",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    }
}
